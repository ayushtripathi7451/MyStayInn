# Backend API host. Required for push notifications and announcements.
# - Android emulator: 10.0.2.2
# - iOS simulator / same machine: localhost or 127.0.0.1
# - Physical device on same WiFi: your PC's IP (e.g. 10.224.3.167)
# Copy to .env and set your value, then restart: npx expo start
EXPO_PUBLIC_API_HOST=10.224.3.167
