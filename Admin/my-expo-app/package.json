    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/messaging": "^23.8.8",
    "@react-navigation/native": "^7.1.20",
    "@react-navigation/native-stack": "^7.6.3",
    "@reduxjs/toolkit": "^2.5.0",
    "axios": "^1.6.8",
    "country-state-city": "^3.2.1",
    "dotenv": "^17.2.3",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
