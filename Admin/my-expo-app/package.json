    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^0.562.0",
    "nativewind": "^4.2.1",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
